        <mxCell id="r3" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimPatient" target="faitSatis"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r4" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimPatient" target="faitDeces"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="r5" style="endArrow=ERmany;startArrow=ERone;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="dimTemps" target="faitConso"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r6" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimTemps" target="faitHospit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r7" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimTemps" target="faitSatis"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r8" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimTemps" target="faitDeces"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="r9" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimDiag" target="faitConso"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r10" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimDiag" target="faitHospit"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="r11" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimEtab" target="faitConso"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r12" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimEtab" target="faitHospit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r13" style="endArrow=ERmany;startArrow=ERone;html=1;" edge="1" parent="1" source="dimEtab" target="faitSatis"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Legende -->
        <mxCell id="leg" value="Legende : Dim (1) --- (N) Fait  |  bleu = dimension partagee conforme  |  vert = table de fait (1 par axe metier)" style="text;html=1;align=left;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="900" height="20" as="geometry" />
        </mxCell>
      </root>
