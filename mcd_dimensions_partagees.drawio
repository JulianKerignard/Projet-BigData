        <mxCell id="faitSatis" value="Fait_Satisfaction&#10;(patient_id, date_id, etab_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="490" width="280" height="70" as="geometry" />
