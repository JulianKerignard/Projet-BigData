<mxfile host="app.diagrams.net" type="device">
  <diagram name="MCD Dimensions partagees" id="mcd-dim-partagees">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Titre -->
        <mxCell id="title" value="MCD - Dimensions partagees (Cloud Healthcare Unit) - modele en etoile" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="840" height="30" as="geometry" />
        </mxCell>

        <!-- ===== DIMENSIONS (colonnes laterales) ===== -->
        <mxCell id="dimPatient" value="Dim_Patient" style="shape=table;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;childLayout=tableLayout;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="patient_id : VARCHAR(64)  [PK]" style="text;html=1;align=left;spacingLeft=6;fontStyle=4;" vertex="1" parent="dimPatient"><mxGeometry y="30" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="p2" value="sexe : CHAR(1) {M,F}" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimPatient"><mxGeometry y="54" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="p3" value="age : INT / date_naissance : DATE" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimPatient"><mxGeometry y="78" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="p4" value="region_residence : VARCHAR(60)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimPatient"><mxGeometry y="102" width="240" height="24" as="geometry"/></mxCell>

        <mxCell id="dimDiag" value="Dim_Diagnostic" style="shape=table;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="diag_id : VARCHAR(20)  [PK]" style="text;html=1;align=left;spacingLeft=6;fontStyle=4;" vertex="1" parent="dimDiag"><mxGeometry y="30" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="d2" value="code_cim10 : VARCHAR(10)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimDiag"><mxGeometry y="54" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="d3" value="libelle : VARCHAR(255)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimDiag"><mxGeometry y="78" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="d4" value="chapitre_cim10 : VARCHAR(120)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimDiag"><mxGeometry y="102" width="240" height="24" as="geometry"/></mxCell>

        <mxCell id="dimTemps" value="Dim_Temps" style="shape=table;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="100" width="240" height="174" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="date_id : INT (YYYYMMDD)  [PK]" style="text;html=1;align=left;spacingLeft=6;fontStyle=4;" vertex="1" parent="dimTemps"><mxGeometry y="30" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="t2" value="jour : INT" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimTemps"><mxGeometry y="54" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="t3" value="mois : INT" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimTemps"><mxGeometry y="78" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="t4" value="trimestre : INT / annee : INT" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimTemps"><mxGeometry y="102" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="t5" value="jour_semaine : VARCHAR(10)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimTemps"><mxGeometry y="126" width="240" height="24" as="geometry"/></mxCell>

        <mxCell id="dimEtab" value="Dim_Etablissement" style="shape=table;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="540" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="etab_id : VARCHAR(20)  [PK]" style="text;html=1;align=left;spacingLeft=6;fontStyle=4;" vertex="1" parent="dimEtab"><mxGeometry y="30" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="e2" value="nom_etab : VARCHAR(255)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimEtab"><mxGeometry y="54" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="e3" value="type_etab : VARCHAR(50)" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimEtab"><mxGeometry y="78" width="240" height="24" as="geometry"/></mxCell>
        <mxCell id="e4" value="region / departement : VARCHAR" style="text;html=1;align=left;spacingLeft=6;" vertex="1" parent="dimEtab"><mxGeometry y="102" width="240" height="24" as="geometry"/></mxCell>

        <!-- ===== FAITS (colonne centrale) ===== -->
        <mxCell id="faitConso" value="Fait_Consultation&#10;(patient_id, date_id, etab_id, diag_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="110" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="faitHospit" value="Fait_Hospitalisation&#10;(patient_id, date_id, etab_id, diag_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="300" width="280" height="70" as="geometry" />
