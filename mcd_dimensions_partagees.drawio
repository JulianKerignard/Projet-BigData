        <mxCell id="faitDeces" value="Fait_Deces&#10;(patient_id, date_id)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="680" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- ===== RELATIONS (1,N) ===== -->
        <mxCell id="r1" style="endArrow=ERmany;startArrow=ERone;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="dimPatient" target="faitConso"><mxGeometry relative="1" as="geometry"/></mxCell>
