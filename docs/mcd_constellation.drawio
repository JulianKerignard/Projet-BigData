        <mxCell id="10" value="<b>Dim_Temps</b><br/>date_id : INT (YYYYMMDD) [PK]<br/>jour : INT<br/>mois : INT<br/>trimestre : INT<br/>annee : INT<br/>jour_semaine : VARCHAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe8fb;strokeColor=#4178c0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="33" y="154" width="374" height="299" as="geometry"/></mxCell>
        <mxCell id="11" value="<b>Dim_Patient</b><br/>patient_id : VARCHAR(64) [PK]<br/>  (hash SHA-256, pseudonymisé)<br/>sexe : CHAR(1) (M/F)<br/>tranche_age : VARCHAR<br/>region_residence : VARCHAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe8fb;strokeColor=#4178c0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="33" y="550" width="374" height="262" as="geometry"/></mxCell>
        <mxCell id="12" value="<b>Dim_Professionnel</b><br/>prof_id : VARCHAR [PK]<br/>specialite : VARCHAR<br/>categorie_prof : VARCHAR<br/>code_specialite : VARCHAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe8fb;strokeColor=#4178c0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="33" y="902" width="374" height="224" as="geometry"/></mxCell>
        <mxCell id="13" value="<b>Dim_Diagnostic</b><br/>diag_id : VARCHAR(20) [PK]<br/>code_cim10 : VARCHAR(10)<br/>libelle : VARCHAR(255)<br/>chapitre_cim10 : VARCHAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe8fb;strokeColor=#4178c0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1386" y="154" width="374" height="224" as="geometry"/></mxCell>
        <mxCell id="14" value="<b>Dim_Etablissement</b><br/>etab_id : VARCHAR(20) [PK]<br/>  (FINESS géographique)<br/>nom_etab : VARCHAR(255)<br/>type_etab : VARCHAR(50)<br/>region / departement : VARCHAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe8fb;strokeColor=#4178c0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1386" y="528" width="374" height="262" as="geometry"/></mxCell>
